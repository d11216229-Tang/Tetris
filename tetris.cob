>>SOURCE FORMAT FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. TETRIS.

ENVIRONMENT DIVISION.

DATA DIVISION.
WORKING-STORAGE SECTION.
01 WS-BOARD.
   05 WS-BOARD-ROW OCCURS 20 TIMES.
      10 WS-BOARD-CELL OCCURS 10 TIMES PIC 9 VALUE 0.

01 WS-GAME-STATE.
   05 WS-CURRENT-PIECE          PIC 9 VALUE 1.
   05 WS-CURRENT-ROTATION       PIC 9 VALUE 1.
   05 WS-CURRENT-X              PIC S99 VALUE 4.
   05 WS-CURRENT-Y              PIC S99 VALUE 0.
   05 WS-GAME-OVER              PIC X VALUE 'N'.
   05 WS-QUIT                   PIC X VALUE 'N'.
   05 WS-PIECE-LOCKED           PIC X VALUE 'N'.

01 WS-SCORE-DATA.
   05 WS-SCORE                  PIC 9(9) VALUE 0.
   05 WS-TOTAL-LINES            PIC 9(9) VALUE 0.
   05 WS-LEVEL                  PIC 9(3) VALUE 1.
   05 WS-EARNED-SCORE           PIC 9(9) VALUE 0.

01 WS-INPUT.
   05 WS-CMD-RAW                PIC X(20).
   05 WS-CMD                    PIC X(20).
   05 WS-ARROW-UP               PIC X(3) VALUE X"1B5B41".
   05 WS-ARROW-DOWN             PIC X(3) VALUE X"1B5B42".
   05 WS-ARROW-RIGHT            PIC X(3) VALUE X"1B5B43".
   05 WS-ARROW-LEFT             PIC X(3) VALUE X"1B5B44".

01 WS-LOOP-VARS.
   05 WS-R                      PIC S99.
   05 WS-C                      PIC S99.
   05 WS-I                      PIC S99.
   05 WS-J                      PIC S99.
   05 WS-TEST-X                 PIC S99.
   05 WS-TEST-Y                 PIC S99.
   05 WS-TEST-ROT               PIC 9.
   05 WS-TEST-PIECE             PIC 9.
   05 WS-LOCAL-R                PIC S99.
   05 WS-LOCAL-C                PIC S99.
   05 WS-BLOCK                  PIC 9 VALUE 0.
   05 WS-HAS-COLLISION          PIC X VALUE 'N'.
   05 WS-LINES-CLEARED          PIC 9 VALUE 0.
   05 WS-ROW-FULL               PIC X VALUE 'N'.
   05 WS-DROP-STEPS             PIC 9 VALUE 1.
   05 WS-DROPS-THIS-TURN        PIC 9 VALUE 0.
   05 WS-RENDER-CELL            PIC 9 VALUE 0.
   05 WS-RAND-SEED              PIC 9(9) VALUE 13579.
   05 WS-RAND-VAL               PIC 9V9(9) VALUE 0.

01 WS-ANSI.
   05 ANSI-ESC                  PIC X VALUE X"1B".
   05 ANSI-RESET                PIC X(4) VALUE SPACES.
   05 ANSI-CLEAR                PIC X(7) VALUE SPACES.
   05 ANSI-GRAY                 PIC X(5) VALUE SPACES.
   05 ANSI-BLACKBG              PIC X(5) VALUE SPACES.
   05 ANSI-CYAN                 PIC X(5) VALUE SPACES.
   05 ANSI-YELLOW               PIC X(5) VALUE SPACES.
   05 ANSI-PURPLE               PIC X(5) VALUE SPACES.
   05 ANSI-ORANGE               PIC X(11) VALUE SPACES.
   05 ANSI-BLUE                 PIC X(5) VALUE SPACES.
   05 ANSI-GREEN                PIC X(5) VALUE SPACES.
   05 ANSI-RED                  PIC X(5) VALUE SPACES.

PROCEDURE DIVISION.
MAIN-PROCEDURE.
    PERFORM INIT-ANSI
    PERFORM INIT-RANDOM
    PERFORM SPAWN-PIECE

    PERFORM UNTIL WS-GAME-OVER = 'Y' OR WS-QUIT = 'Y'
        PERFORM RENDER
        PERFORM READ-COMMAND
        PERFORM HANDLE-COMMAND
        IF WS-PIECE-LOCKED = 'N'
            PERFORM APPLY-AUTO-DROP
        END-IF
    END-PERFORM

    PERFORM RENDER
    IF WS-QUIT = 'Y'
        DISPLAY "\nBye. Final Score: " WS-SCORE
    ELSE
        DISPLAY "\nGAME OVER! Final Score: " WS-SCORE
    END-IF
    DISPLAY ANSI-RESET
    STOP RUN.

INIT-ANSI.
    STRING ANSI-ESC "[0m" DELIMITED BY SIZE INTO ANSI-RESET
    STRING ANSI-ESC "[2J" ANSI-ESC "[H" DELIMITED BY SIZE INTO ANSI-CLEAR
    STRING ANSI-ESC "[90m" DELIMITED BY SIZE INTO ANSI-GRAY
    STRING ANSI-ESC "[40m" DELIMITED BY SIZE INTO ANSI-BLACKBG
    STRING ANSI-ESC "[36m" DELIMITED BY SIZE INTO ANSI-CYAN
    STRING ANSI-ESC "[33m" DELIMITED BY SIZE INTO ANSI-YELLOW
    STRING ANSI-ESC "[35m" DELIMITED BY SIZE INTO ANSI-PURPLE
    STRING ANSI-ESC "[38;5;208m" DELIMITED BY SIZE INTO ANSI-ORANGE
    STRING ANSI-ESC "[34m" DELIMITED BY SIZE INTO ANSI-BLUE
    STRING ANSI-ESC "[32m" DELIMITED BY SIZE INTO ANSI-GREEN
    STRING ANSI-ESC "[31m" DELIMITED BY SIZE INTO ANSI-RED.

INIT-RANDOM.
    COMPUTE WS-RAND-SEED = FUNCTION INTEGER(FUNCTION RANDOM(0) * 1000000)
    COMPUTE WS-RAND-VAL = FUNCTION RANDOM(WS-RAND-SEED).

READ-COMMAND.
    DISPLAY "Command [A/D/W/S or arrows(LEFT/RIGHT/UP/DOWN), Space/Enter=drop, Q=quit]: " NO ADVANCING
    ACCEPT WS-CMD-RAW
    MOVE FUNCTION UPPER-CASE(FUNCTION TRIM(WS-CMD-RAW)) TO WS-CMD.

HANDLE-COMMAND.
    MOVE 'N' TO WS-PIECE-LOCKED
    IF WS-CMD = "Q"
        MOVE 'Y' TO WS-QUIT
        EXIT PARAGRAPH
    END-IF

    EVALUATE TRUE
        WHEN WS-CMD = "A"
             OR WS-CMD = "LEFT"
             OR WS-CMD-RAW(1:3) = WS-ARROW-LEFT
            PERFORM TRY-MOVE-LEFT
        WHEN WS-CMD = "D"
             OR WS-CMD = "RIGHT"
             OR WS-CMD-RAW(1:3) = WS-ARROW-RIGHT
            PERFORM TRY-MOVE-RIGHT
        WHEN WS-CMD = "W"
             OR WS-CMD = "UP"
             OR WS-CMD-RAW(1:3) = WS-ARROW-UP
            PERFORM TRY-ROTATE
        WHEN WS-CMD = "S"
             OR WS-CMD = "DOWN"
             OR WS-CMD-RAW(1:3) = WS-ARROW-DOWN
            MOVE 2 TO WS-DROP-STEPS
            PERFORM APPLY-DROP-STEPS
        WHEN OTHER
            IF FUNCTION LENGTH(FUNCTION TRIM(WS-CMD)) = 0
                PERFORM HARD-DROP
            END-IF
    END-EVALUATE.

APPLY-AUTO-DROP.
    COMPUTE WS-DROP-STEPS = 1 + ((WS-LEVEL - 1) / 3)
    IF WS-DROP-STEPS < 1
        MOVE 1 TO WS-DROP-STEPS
    END-IF
    PERFORM APPLY-DROP-STEPS.

APPLY-DROP-STEPS.
    MOVE 0 TO WS-DROPS-THIS-TURN
    PERFORM VARYING WS-I FROM 1 BY 1 UNTIL WS-I > WS-DROP-STEPS
        IF WS-PIECE-LOCKED = 'Y'
            EXIT PERFORM
        END-IF
        PERFORM TRY-MOVE-DOWN
    END-PERFORM.

TRY-MOVE-LEFT.
    MOVE WS-CURRENT-X TO WS-TEST-X
    SUBTRACT 1 FROM WS-TEST-X
    MOVE WS-CURRENT-Y TO WS-TEST-Y
    MOVE WS-CURRENT-ROTATION TO WS-TEST-ROT
    PERFORM CHECK-COLLISION
    IF WS-HAS-COLLISION = 'N'
        SUBTRACT 1 FROM WS-CURRENT-X
    END-IF.

TRY-MOVE-RIGHT.
    MOVE WS-CURRENT-X TO WS-TEST-X
    ADD 1 TO WS-TEST-X
    MOVE WS-CURRENT-Y TO WS-TEST-Y
    MOVE WS-CURRENT-ROTATION TO WS-TEST-ROT
    PERFORM CHECK-COLLISION
    IF WS-HAS-COLLISION = 'N'
        ADD 1 TO WS-CURRENT-X
    END-IF.

TRY-ROTATE.
    MOVE WS-CURRENT-X TO WS-TEST-X
    MOVE WS-CURRENT-Y TO WS-TEST-Y
    COMPUTE WS-TEST-ROT = WS-CURRENT-ROTATION + 1
    IF WS-TEST-ROT > 4
        MOVE 1 TO WS-TEST-ROT
    END-IF
    PERFORM CHECK-COLLISION
    IF WS-HAS-COLLISION = 'N'
        MOVE WS-TEST-ROT TO WS-CURRENT-ROTATION
    END-IF.

TRY-MOVE-DOWN.
    MOVE WS-CURRENT-X TO WS-TEST-X
    MOVE WS-CURRENT-Y TO WS-TEST-Y
    ADD 1 TO WS-TEST-Y
    MOVE WS-CURRENT-ROTATION TO WS-TEST-ROT
    PERFORM CHECK-COLLISION
    IF WS-HAS-COLLISION = 'N'
        ADD 1 TO WS-CURRENT-Y
    ELSE
        PERFORM LOCK-CURRENT-PIECE
    END-IF.

HARD-DROP.
    PERFORM UNTIL WS-PIECE-LOCKED = 'Y'
        PERFORM TRY-MOVE-DOWN
    END-PERFORM.

LOCK-CURRENT-PIECE.
    PERFORM VARYING WS-R FROM 1 BY 1 UNTIL WS-R > 4
        PERFORM VARYING WS-C FROM 1 BY 1 UNTIL WS-C > 4
            MOVE WS-CURRENT-PIECE TO WS-TEST-PIECE
            MOVE WS-CURRENT-ROTATION TO WS-TEST-ROT
            MOVE WS-R TO WS-LOCAL-R
            MOVE WS-C TO WS-LOCAL-C
            PERFORM PIECE-BLOCK-AT
            IF WS-BLOCK = 1
                COMPUTE WS-TEST-Y = WS-CURRENT-Y + WS-R - 1
                COMPUTE WS-TEST-X = WS-CURRENT-X + WS-C - 1
                IF WS-TEST-Y >= 1 AND WS-TEST-Y <= 20
                    MOVE WS-CURRENT-PIECE TO WS-BOARD-CELL(WS-TEST-Y, WS-TEST-X)
                END-IF
            END-IF
        END-PERFORM
    END-PERFORM

    PERFORM CLEAR-LINES
    PERFORM SPAWN-PIECE
    MOVE 'Y' TO WS-PIECE-LOCKED.

CLEAR-LINES.
    MOVE 0 TO WS-LINES-CLEARED
    PERFORM VARYING WS-R FROM 20 BY -1 UNTIL WS-R < 1
        MOVE 'Y' TO WS-ROW-FULL
        PERFORM VARYING WS-C FROM 1 BY 1 UNTIL WS-C > 10
            IF WS-BOARD-CELL(WS-R, WS-C) = 0
                MOVE 'N' TO WS-ROW-FULL
            END-IF
        END-PERFORM

        IF WS-ROW-FULL = 'Y'
            ADD 1 TO WS-LINES-CLEARED
            PERFORM SHIFT-DOWN-FROM-ROW
            ADD 1 TO WS-R
        END-IF
    END-PERFORM

    IF WS-LINES-CLEARED > 0
        ADD WS-LINES-CLEARED TO WS-TOTAL-LINES
        COMPUTE WS-LEVEL = (WS-TOTAL-LINES / 10) + 1
        MOVE 0 TO WS-EARNED-SCORE
        EVALUATE WS-LINES-CLEARED
            WHEN 1
                COMPUTE WS-EARNED-SCORE = 100 * WS-LEVEL
            WHEN 2
                COMPUTE WS-EARNED-SCORE = 300 * WS-LEVEL
            WHEN 3
                COMPUTE WS-EARNED-SCORE = 500 * WS-LEVEL
            WHEN 4
                COMPUTE WS-EARNED-SCORE = 800 * WS-LEVEL
        END-EVALUATE
        ADD WS-EARNED-SCORE TO WS-SCORE
    END-IF.

SHIFT-DOWN-FROM-ROW.
    PERFORM VARYING WS-I FROM WS-R BY -1 UNTIL WS-I < 2
        PERFORM VARYING WS-C FROM 1 BY 1 UNTIL WS-C > 10
            MOVE WS-BOARD-CELL(WS-I - 1, WS-C) TO WS-BOARD-CELL(WS-I, WS-C)
        END-PERFORM
    END-PERFORM

    PERFORM VARYING WS-C FROM 1 BY 1 UNTIL WS-C > 10
        MOVE 0 TO WS-BOARD-CELL(1, WS-C)
    END-PERFORM.

SPAWN-PIECE.
    COMPUTE WS-RAND-VAL = FUNCTION RANDOM
    COMPUTE WS-CURRENT-PIECE = FUNCTION INTEGER(WS-RAND-VAL * 7) + 1
    MOVE 1 TO WS-CURRENT-ROTATION
    MOVE 4 TO WS-CURRENT-X
    MOVE 0 TO WS-CURRENT-Y

    MOVE WS-CURRENT-X TO WS-TEST-X
    MOVE WS-CURRENT-Y TO WS-TEST-Y
    MOVE WS-CURRENT-ROTATION TO WS-TEST-ROT
    PERFORM CHECK-COLLISION
    IF WS-HAS-COLLISION = 'Y'
        MOVE 'Y' TO WS-GAME-OVER
    END-IF.

CHECK-COLLISION.
    MOVE 'N' TO WS-HAS-COLLISION
    PERFORM VARYING WS-R FROM 1 BY 1 UNTIL WS-R > 4
        PERFORM VARYING WS-C FROM 1 BY 1 UNTIL WS-C > 4
            MOVE WS-CURRENT-PIECE TO WS-TEST-PIECE
            MOVE WS-R TO WS-LOCAL-R
            MOVE WS-C TO WS-LOCAL-C
            PERFORM PIECE-BLOCK-AT
            IF WS-BLOCK = 1
                COMPUTE WS-LOCAL-R = WS-TEST-Y + WS-R - 1
                COMPUTE WS-LOCAL-C = WS-TEST-X + WS-C - 1

                IF WS-LOCAL-C < 1 OR WS-LOCAL-C > 10 OR WS-LOCAL-R > 20
                    MOVE 'Y' TO WS-HAS-COLLISION
                ELSE
                    IF WS-LOCAL-R >= 1
                        IF WS-BOARD-CELL(WS-LOCAL-R, WS-LOCAL-C) NOT = 0
                            MOVE 'Y' TO WS-HAS-COLLISION
                        END-IF
                    END-IF
                END-IF
            END-IF
        END-PERFORM
    END-PERFORM.

PIECE-BLOCK-AT.
    MOVE 0 TO WS-BLOCK
    EVALUATE WS-TEST-PIECE
        WHEN 1
            PERFORM PIECE-I-BLOCK
        WHEN 2
            PERFORM PIECE-O-BLOCK
        WHEN 3
            PERFORM PIECE-T-BLOCK
        WHEN 4
            PERFORM PIECE-J-BLOCK
        WHEN 5
            PERFORM PIECE-L-BLOCK
        WHEN 6
            PERFORM PIECE-S-BLOCK
        WHEN 7
            PERFORM PIECE-Z-BLOCK
    END-EVALUATE.

PIECE-I-BLOCK.
    IF WS-TEST-ROT = 1 OR WS-TEST-ROT = 3
        IF WS-LOCAL-R = 2 AND WS-LOCAL-C >= 1 AND WS-LOCAL-C <= 4
            MOVE 1 TO WS-BLOCK
        END-IF
    ELSE
        IF WS-LOCAL-C = 2 AND WS-LOCAL-R >= 1 AND WS-LOCAL-R <= 4
            MOVE 1 TO WS-BLOCK
        END-IF
    END-IF.

PIECE-O-BLOCK.
    IF WS-LOCAL-R >= 1 AND WS-LOCAL-R <= 2 AND WS-LOCAL-C >= 2 AND WS-LOCAL-C <= 3
        MOVE 1 TO WS-BLOCK
    END-IF.

PIECE-T-BLOCK.
    EVALUATE WS-TEST-ROT
        WHEN 1
            IF (WS-LOCAL-R = 1 AND WS-LOCAL-C = 2)
               OR (WS-LOCAL-R = 2 AND WS-LOCAL-C >= 1 AND WS-LOCAL-C <= 3)
                MOVE 1 TO WS-BLOCK
            END-IF
        WHEN 2
            IF (WS-LOCAL-R = 1 AND WS-LOCAL-C = 2)
               OR (WS-LOCAL-R = 2 AND WS-LOCAL-C = 2)
               OR (WS-LOCAL-R = 3 AND WS-LOCAL-C = 2)
               OR (WS-LOCAL-R = 2 AND WS-LOCAL-C = 3)
                MOVE 1 TO WS-BLOCK
            END-IF
        WHEN 3
            IF (WS-LOCAL-R = 2 AND WS-LOCAL-C >= 1 AND WS-LOCAL-C <= 3)
               OR (WS-LOCAL-R = 3 AND WS-LOCAL-C = 2)
                MOVE 1 TO WS-BLOCK
            END-IF
        WHEN 4
            IF (WS-LOCAL-R = 1 AND WS-LOCAL-C = 2)
               OR (WS-LOCAL-R = 2 AND WS-LOCAL-C = 1)
               OR (WS-LOCAL-R = 2 AND WS-LOCAL-C = 2)
               OR (WS-LOCAL-R = 3 AND WS-LOCAL-C = 2)
                MOVE 1 TO WS-BLOCK
            END-IF
    END-EVALUATE.

PIECE-J-BLOCK.
    EVALUATE WS-TEST-ROT
        WHEN 1
            IF (WS-LOCAL-R = 1 AND WS-LOCAL-C = 1)
               OR (WS-LOCAL-R = 2 AND WS-LOCAL-C >= 1 AND WS-LOCAL-C <= 3)
                MOVE 1 TO WS-BLOCK
            END-IF
        WHEN 2
            IF (WS-LOCAL-R = 1 AND WS-LOCAL-C = 2)
               OR (WS-LOCAL-R = 1 AND WS-LOCAL-C = 3)
               OR (WS-LOCAL-R = 2 AND WS-LOCAL-C = 2)
               OR (WS-LOCAL-R = 3 AND WS-LOCAL-C = 2)
                MOVE 1 TO WS-BLOCK
            END-IF
        WHEN 3
            IF (WS-LOCAL-R = 2 AND WS-LOCAL-C >= 1 AND WS-LOCAL-C <= 3)
               OR (WS-LOCAL-R = 3 AND WS-LOCAL-C = 3)
                MOVE 1 TO WS-BLOCK
            END-IF
        WHEN 4
            IF (WS-LOCAL-R = 1 AND WS-LOCAL-C = 2)
               OR (WS-LOCAL-R = 2 AND WS-LOCAL-C = 2)
               OR (WS-LOCAL-R = 3 AND WS-LOCAL-C = 1)
               OR (WS-LOCAL-R = 3 AND WS-LOCAL-C = 2)
                MOVE 1 TO WS-BLOCK
            END-IF
    END-EVALUATE.

PIECE-L-BLOCK.
    EVALUATE WS-TEST-ROT
        WHEN 1
            IF (WS-LOCAL-R = 1 AND WS-LOCAL-C = 3)
               OR (WS-LOCAL-R = 2 AND WS-LOCAL-C >= 1 AND WS-LOCAL-C <= 3)
                MOVE 1 TO WS-BLOCK
            END-IF
        WHEN 2
            IF (WS-LOCAL-R = 1 AND WS-LOCAL-C = 2)
               OR (WS-LOCAL-R = 2 AND WS-LOCAL-C = 2)
               OR (WS-LOCAL-R = 3 AND WS-LOCAL-C = 2)
               OR (WS-LOCAL-R = 3 AND WS-LOCAL-C = 3)
                MOVE 1 TO WS-BLOCK
            END-IF
        WHEN 3
            IF (WS-LOCAL-R = 2 AND WS-LOCAL-C >= 1 AND WS-LOCAL-C <= 3)
               OR (WS-LOCAL-R = 3 AND WS-LOCAL-C = 1)
                MOVE 1 TO WS-BLOCK
            END-IF
        WHEN 4
            IF (WS-LOCAL-R = 1 AND WS-LOCAL-C = 1)
               OR (WS-LOCAL-R = 1 AND WS-LOCAL-C = 2)
               OR (WS-LOCAL-R = 2 AND WS-LOCAL-C = 2)
               OR (WS-LOCAL-R = 3 AND WS-LOCAL-C = 2)
                MOVE 1 TO WS-BLOCK
            END-IF
    END-EVALUATE.

PIECE-S-BLOCK.
    IF WS-TEST-ROT = 1 OR WS-TEST-ROT = 3
        IF (WS-LOCAL-R = 1 AND (WS-LOCAL-C = 2 OR WS-LOCAL-C = 3))
           OR (WS-LOCAL-R = 2 AND (WS-LOCAL-C = 1 OR WS-LOCAL-C = 2))
            MOVE 1 TO WS-BLOCK
        END-IF
    ELSE
        IF (WS-LOCAL-R = 1 AND WS-LOCAL-C = 2)
           OR (WS-LOCAL-R = 2 AND WS-LOCAL-C = 2)
           OR (WS-LOCAL-R = 2 AND WS-LOCAL-C = 3)
           OR (WS-LOCAL-R = 3 AND WS-LOCAL-C = 3)
            MOVE 1 TO WS-BLOCK
        END-IF
    END-IF.

PIECE-Z-BLOCK.
    IF WS-TEST-ROT = 1 OR WS-TEST-ROT = 3
        IF (WS-LOCAL-R = 1 AND (WS-LOCAL-C = 1 OR WS-LOCAL-C = 2))
           OR (WS-LOCAL-R = 2 AND (WS-LOCAL-C = 2 OR WS-LOCAL-C = 3))
            MOVE 1 TO WS-BLOCK
        END-IF
    ELSE
        IF (WS-LOCAL-R = 1 AND WS-LOCAL-C = 3)
           OR (WS-LOCAL-R = 2 AND WS-LOCAL-C = 2)
           OR (WS-LOCAL-R = 2 AND WS-LOCAL-C = 3)
           OR (WS-LOCAL-R = 3 AND WS-LOCAL-C = 2)
            MOVE 1 TO WS-BLOCK
        END-IF
    END-IF.

RENDER.
    DISPLAY ANSI-CLEAR NO ADVANCING
    DISPLAY ANSI-BLACKBG ANSI-RESET
    DISPLAY "Score: " WS-SCORE "   Level: " WS-LEVEL "   Lines: " WS-TOTAL-LINES
    DISPLAY "Colors: I=cyan O=yellow T=purple J=orange L=blue S=green Z=red"

    DISPLAY ANSI-GRAY "+--------------------+" ANSI-RESET
    PERFORM VARYING WS-R FROM 1 BY 1 UNTIL WS-R > 20
        DISPLAY ANSI-GRAY "|" NO ADVANCING
        PERFORM VARYING WS-C FROM 1 BY 1 UNTIL WS-C > 10
            PERFORM GET-RENDER-CELL
            PERFORM DISPLAY-RENDER-CELL
            DISPLAY ANSI-GRAY "|" NO ADVANCING
        END-PERFORM
        DISPLAY ANSI-RESET
        DISPLAY ANSI-GRAY "+--------------------+" ANSI-RESET
    END-PERFORM.

GET-RENDER-CELL.
    MOVE WS-BOARD-CELL(WS-R, WS-C) TO WS-RENDER-CELL
    COMPUTE WS-LOCAL-R = WS-R - WS-CURRENT-Y + 1
    COMPUTE WS-LOCAL-C = WS-C - WS-CURRENT-X + 1
    IF WS-LOCAL-R >= 1 AND WS-LOCAL-R <= 4 AND WS-LOCAL-C >= 1 AND WS-LOCAL-C <= 4
        MOVE WS-CURRENT-PIECE TO WS-TEST-PIECE
        MOVE WS-CURRENT-ROTATION TO WS-TEST-ROT
        PERFORM PIECE-BLOCK-AT
        IF WS-BLOCK = 1
            MOVE WS-CURRENT-PIECE TO WS-RENDER-CELL
        END-IF
    END-IF.

DISPLAY-RENDER-CELL.
    EVALUATE WS-RENDER-CELL
        WHEN 0
            DISPLAY ANSI-BLACKBG "  " ANSI-RESET NO ADVANCING
        WHEN 1
            DISPLAY ANSI-CYAN "[]" ANSI-RESET NO ADVANCING
        WHEN 2
            DISPLAY ANSI-YELLOW "[]" ANSI-RESET NO ADVANCING
        WHEN 3
            DISPLAY ANSI-PURPLE "[]" ANSI-RESET NO ADVANCING
        WHEN 4
            DISPLAY ANSI-ORANGE "[]" ANSI-RESET NO ADVANCING
        WHEN 5
            DISPLAY ANSI-BLUE "[]" ANSI-RESET NO ADVANCING
        WHEN 6
            DISPLAY ANSI-GREEN "[]" ANSI-RESET NO ADVANCING
        WHEN 7
            DISPLAY ANSI-RED "[]" ANSI-RESET NO ADVANCING
    END-EVALUATE.

END PROGRAM TETRIS.
